AIRFLOW_UID=50000
AIRFLOW_IMAGE_NAME=data-pipeline-airflow:latest
AIRFLOW_PROJ_DIR=.
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow
# AIRFLOW_WORKER_CONCURRENCY: 4 for sample/train, 2 for test.
AIRFLOW_WORKER_CONCURRENCY=2

# DATA_PIPELINE_MODE: sample (WY, 5K rows) | train (50 states, 5K/state) | test (50 states, sum(PWGTP)//10 per state)
DATA_PIPELINE_MODE=test
